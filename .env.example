# Neon PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@EP-EXAMPLE-123456.ap-southeast-1.aws.neon.tech/dartcrossings?sslmode=require"

# Optional direct connection for Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@EP-EXAMPLE-123456.ap-southeast-1.aws.neon.tech/dartcrossings?sslmode=require"

# Public app URL used for links, redirects, and metadata.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe publishable key for frontend checkout initialization.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"

# Stripe secret key for server-side Checkout session operations.
STRIPE_SECRET_KEY="sk_test_your_secret_key_here"


# Secret used to sign the admin session cookie.
ADMIN_SESSION_SECRET="replace_with_a_long_random_secret_at_least_32_chars"
